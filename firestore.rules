rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == "stratproamz@gmail.com";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Identity Logic
    // For merchants, their shopId IS their uid.
    // For staff, we must verify their association.
    function userBelongsToShop(shopId) {
      return isSignedIn() && (
        request.auth.uid == shopId || // Merchant self
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == shopId) // Staff lookup
      );
    }

    // Validation Blueprints
    function isValidProduct(data) {
      return data.shopId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0;
    }

    function isValidSale(data) {
      return data.shopId is string &&
             data.items is list && data.items.size() > 0 &&
             data.finalAmount is number && data.finalAmount >= 0;
    }

    function isValidCustomer(data) {
      return data.shopId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidUser(data) {
      return data.shopId is string &&
             data.username is string && data.role in ['admin', 'staff', 'manager', 'sales', 'inventory', 'cashier'];
    }

    function isValidShop(data) {
      return data.shopId is string && data.name is string && data.ownerUid == request.auth.uid;
    }

    // 4. Detailed Match Blocks
    
    // Core Business Collections
    match /{collection}/{docId} {
      // Use dynamic matching for common shop data
      allow list: if isMasterAdmin() || (
        isSignedIn() && (
          // Master check for list: can we verify the shopId in the query?
          // Since we can't get() in list, we rely on the merchant check or master admin
          request.auth.uid == resource.data.shopId || 
          isMasterAdmin()
        )
      );

      allow get: if isMasterAdmin() || userBelongsToShop(existing().shopId);

      allow create: if isMasterAdmin() || (
        userBelongsToShop(incoming().shopId) &&
        isValidId(docId) &&
        (
          (collection == 'products' && isValidProduct(incoming())) ||
          (collection == 'sales' && isValidSale(incoming())) ||
          (collection == 'customers' && isValidCustomer(incoming())) ||
          (collection == 'users' && isValidUser(incoming())) ||
          (collection == 'notes' && incoming().text is string) ||
          (collection == 'categories' && incoming().name is string) ||
          (collection == 'expenses') || (collection == 'investments') || (collection == 'employees') || 
          (collection == 'due_payments') || (collection == 'customer_logs') || (collection == 'staff_salaries') ||
          (collection == 'recycleBin') || (collection == 'stockRecords') || (collection == 'daily_closings')
        )
      );

      allow update: if isMasterAdmin() || (
        userBelongsToShop(existing().shopId) &&
        incoming().shopId == existing().shopId &&
        // Protect roles and sensitive fields
        (collection != 'users' || !incoming().diff(existing()).affectedKeys().hasAny(['role', 'shopId']))
      );

      allow delete: if isMasterAdmin() || (
        userBelongsToShop(existing().shopId) &&
        collection in ['recycleBin', 'categories', 'products']
      );
    }

    // Settings
    match /settings/{shopId} {
      allow read, write: if isMasterAdmin() || userBelongsToShop(shopId);
    }

    // Global Shops Registry
    match /shops/{shopId} {
      allow read: if isMasterAdmin() || (isSignedIn() && request.auth.uid == shopId);
      allow create: if isVerified() && request.auth.uid == shopId && isValidShop(request.resource.data);
      allow update: if isMasterAdmin() || (isSignedIn() && request.auth.uid == shopId);
      allow delete: if isMasterAdmin();
    }
  }
}

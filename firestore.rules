rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Override for Master Admin
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // 2. Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             (request.auth.token.email == "stratproamz@gmail.com" ||
              request.auth.token.email.matches("(?i)^stratproamz@gmail\\.com$"));
    }

    function isOwnerOrStaff(shopId) {
      return isSignedIn() && (
        request.auth.uid == shopId || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == shopId)
      );
    }

    // 4. Test Match Block
    match /test/{docId} {
      allow read, write: if true;
    }
    
    // 3. Match Blocks
    
    // Categories Match Block
    match /categories/{docId} {
      allow read: if true;
      allow create, update: if isMasterAdmin() || (
        isSignedIn() && 
        request.resource != null && 
        request.resource.data.shopId != null && 
        isOwnerOrStaff(request.resource.data.shopId)
      );
      allow delete: if isMasterAdmin() || (
        isSignedIn() && 
        resource != null && 
        resource.data.shopId != null && 
        isOwnerOrStaff(resource.data.shopId)
      );
    }

    // Products Match Block
    match /products/{docId} {
      allow read: if true;
      allow create, update: if isMasterAdmin() || (
        isSignedIn() && 
        request.resource != null && 
        request.resource.data.shopId != null && 
        isOwnerOrStaff(request.resource.data.shopId)
      );
      allow delete: if isMasterAdmin() || (
        isSignedIn() && 
        resource != null && 
        resource.data.shopId != null && 
        isOwnerOrStaff(resource.data.shopId)
      );
    }

    // Customers Match Block
    match /customers/{docId} {
      allow read: if isMasterAdmin() || 
                    (resource != null && resource.data.shopId != null && isOwnerOrStaff(resource.data.shopId)) || 
                    (resource == null || resource.data.phone != null);
      allow create: if true;
      allow update: if isMasterAdmin() || (
        isSignedIn() && 
        resource != null && 
        resource.data.shopId != null && 
        isOwnerOrStaff(resource.data.shopId)
      );
      allow delete: if isMasterAdmin() || (
        isSignedIn() && 
        resource != null && 
        resource.data.shopId != null && 
        isOwnerOrStaff(resource.data.shopId)
      );
    }

    // Customer Orders Match Block
    match /customer_orders/{docId} {
      allow read: if isMasterAdmin() || 
                    (resource != null && resource.data.shopId != null && isOwnerOrStaff(resource.data.shopId)) || 
                    (resource == null || resource.data.customerPhone != null);
      allow create: if true;
      allow update: if isMasterAdmin() || (
        isSignedIn() && 
        resource != null && 
        resource.data.shopId != null && 
        isOwnerOrStaff(resource.data.shopId)
      );
      allow delete: if isMasterAdmin() || (
        isSignedIn() && 
        resource != null && 
        resource.data.shopId != null && 
        isOwnerOrStaff(resource.data.shopId)
      );
    }

    // Generic Shop Data match block (expenses, investments, etc.)
    match /{collection}/{docId} {
      allow read: if !(collection in ['categories', 'products', 'customers', 'customer_orders', 'users', 'settings', 'shops', 'sales']) && (
        isMasterAdmin() || (
          isSignedIn() && (
            resource == null || (
              resource.data.shopId != null &&
              isOwnerOrStaff(resource.data.shopId)
            )
          )
        )
      );
      
      allow create: if !(collection in ['categories', 'products', 'customers', 'customer_orders', 'users', 'settings', 'shops', 'sales']) && (
        isMasterAdmin() || (
          isSignedIn() && 
          request.resource != null && 
          request.resource.data.shopId != null && 
          isOwnerOrStaff(request.resource.data.shopId)
        )
      );

      allow update: if !(collection in ['categories', 'products', 'customers', 'customer_orders', 'users', 'settings', 'shops', 'sales']) && (
        isMasterAdmin() || (
          isSignedIn() && 
          resource != null && 
          resource.data.shopId != null && 
          isOwnerOrStaff(resource.data.shopId) && 
          request.resource != null && 
          request.resource.data.shopId == resource.data.shopId
        )
      );

      allow delete: if !(collection in ['categories', 'products', 'customers', 'customer_orders', 'users', 'settings', 'shops', 'sales']) && (
        isMasterAdmin() || (
          isSignedIn() && 
          resource != null && 
          resource.data.shopId != null && 
          isOwnerOrStaff(resource.data.shopId) && 
          collection in ['recycleBin', 'daily_closings', 'expenses', 'investments', 'staff_salaries', 'stockRecords', 'branches', 'employees', 'notes', 'customer_logs', 'due_payments', 'warranty_records']
        )
      );
    }

    // Sales Match Block (to allow public customer invoice retrieval by document ID, while securing general sales from query scraping)
    match /sales/{docId} {
      allow get: if true; // allow fetching a single invoice by its EXACT document ID
      allow list: if isMasterAdmin() || (
        isSignedIn() && 
        resource != null && 
        resource.data.shopId != null && 
        isOwnerOrStaff(resource.data.shopId)
      );
      allow create: if isMasterAdmin() || (
        isSignedIn() && 
        request.resource != null && 
        request.resource.data.shopId != null && 
        isOwnerOrStaff(request.resource.data.shopId)
      );
      allow update: if isMasterAdmin() || (
        isSignedIn() && 
        resource != null && 
        resource.data.shopId != null && 
        isOwnerOrStaff(resource.data.shopId) && 
        request.resource != null && 
        request.resource.data.shopId == resource.data.shopId
      );
      allow delete: if isMasterAdmin() || (
        isSignedIn() && 
        resource != null && 
        resource.data.shopId != null && 
        isOwnerOrStaff(resource.data.shopId)
      );
    }

    match /settings/{shopId} {
      allow read: if isMasterAdmin() || isOwnerOrStaff(shopId);
      allow write: if isMasterAdmin() || isOwnerOrStaff(shopId);
    }

    match /shops {
      allow read: if true;
    }

    match /shops/{shopId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == shopId;
      allow update: if isMasterAdmin() || isOwnerOrStaff(shopId);
      allow delete: if isMasterAdmin();
    }
    
    match /users/{userId} {
      allow read: if isMasterAdmin() || (isSignedIn() && (
        request.auth.uid == userId || 
        (resource != null && (
          resource.data.shopId == request.auth.uid || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == resource.data.shopId)
        ))
      ));
      
      allow create: if isMasterAdmin() || (isSignedIn() && (
        request.auth.uid == userId ||
        (request.resource != null && request.resource.data.shopId != null && (
          request.auth.uid == request.resource.data.shopId ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == request.resource.data.shopId)
        ))
      ));

      allow update: if isMasterAdmin() || (isSignedIn() && (
        request.auth.uid == userId ||
        (resource != null && resource.data.shopId != null && (
          request.auth.uid == resource.data.shopId ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == resource.data.shopId)
        ))
      ));

      allow delete: if isMasterAdmin() || (isSignedIn() && (
        request.auth.uid == userId ||
        (resource != null && resource.data.shopId != null && (
          request.auth.uid == resource.data.shopId ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == resource.data.shopId)
        ))
      ));
    }
  }
}

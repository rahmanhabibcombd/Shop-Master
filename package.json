{
  "name": "react-example",
  "description": "ShopMaster - WhatsApp POS Sync Super Shop Management System",
  "author": "RAHMAN HABIB <stratproamz@gmail.com>",
  "private": true,
  "files": [
    "dist",
    "src",
    "public",
    "*"
  ],
  "version": "1.0.3",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:dev": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^5.0.6",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.9",
    "esbuild": "^0.27.7",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "hls.js": "^1.6.16",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "idb": "^8.0.3",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.0.0",
    "react-is": "^18.3.1",
    "react-qr-code": "^2.0.21",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "autoprefixer": "^10.4.21",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tsx": "^4.21.0"
  },
  "supportedArchitectures": {
    "os": [
      "win32",
      "linux",
      "darwin"
    ],
    "cpu": [
      "x64",
      "arm64"
    ],
    "libc": [
      "glibc",
      "musl"
    ]
  },
  "build": {
    "appId": "com.shopmaster.pos",
    "productName": "ShopMaster",
    "publish": {
      "provider": "github",
      "owner": "Stratprollc",
      "repo": "Shop-Master"
    },
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "public/**/*",
      "firebase-applet-config.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShopMaster POS Sync"
    }
  }
}

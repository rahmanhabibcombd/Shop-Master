{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "barcode": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A sales transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "discount": { "type": "number" },
        "finalAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "sellerId": { "type": "string" }
      },
      "required": ["items", "totalAmount", "finalAmount", "timestamp"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A shop customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "points": { "type": "number" },
        "totalSpent": { "type": "number" },
        "currentDue": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" }
      },
      "required": ["name"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A shop expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string", "enum": ["salary", "rent", "electricity", "internet", "food", "others"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "staffId": { "type": "string" }
      },
      "required": ["category", "amount", "timestamp"]
    },
    "Investment": {
      "title": "Investment",
      "description": "A business investment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "timestamp"]
    },
    "StaffSalary": {
      "title": "StaffSalary",
      "description": "Salary payment to staff",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "staffName": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["staffName", "amount", "month", "timestamp"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "User": {
      "title": "User",
      "description": "System user/staff",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Employee": {
      "title": "Employee",
      "description": "A shop employee",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "designation": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "salary": { "type": "number" },
        "joiningDate": { "type": "string", "format": "date" },
        "schedule": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["name", "designation", "phone", "salary"]
    },
    "StockRecord": {
      "title": "StockRecord",
      "description": "A record of stock addition or adjustment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "type": { "type": "string", "enum": ["add", "sale", "return", "adjustment"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date" },
        "batchNumber": { "type": "string" },
        "location": { "type": "string" },
        "note": { "type": "string" }
      },
      "required": ["productId", "quantity", "type", "timestamp"]
    },
    "RecycleItem": {
      "title": "RecycleItem",
      "description": "An item moved to the recycle bin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityType": { "type": "string", "enum": ["product", "sale", "customer", "expense", "stockRecord", "employee", "investment", "salary", "daily_closing"] },
        "originalId": { "type": "string" },
        "data": { "type": "object" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "deletedBy": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["entityType", "originalId", "data", "deletedAt", "expiresAt"]
    },
    "CustomerLog": {
      "title": "CustomerLog",
      "description": "Historical log of changes to a customer profile or status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "type": { "type": "string", "enum": ["profile_edit", "manual_due", "csv_import"] },
        "oldData": { "type": "object" },
        "newData": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "performedBy": { "type": "string" },
        "performedByRole": { "type": "string" }
      },
      "required": ["customerId", "type", "timestamp", "performedBy"]
    },
    "DuePayment": {
      "title": "DuePayment",
      "description": "A payment made by a customer to clear outstanding debt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "amount": { "type": "number" },
        "previousDue": { "type": "number" },
        "remainingDue": { "type": "number" },
        "method": { "type": "string", "enum": ["cash", "bkash", "nagad", "bank"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "receivedBy": { "type": "string" },
        "note": { "type": "string" }
      },
      "required": ["customerId", "amount", "method", "timestamp", "receivedBy"]
    },
    "Note": {
      "title": "Note",
      "description": "A personal note",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "color": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "color", "timestamp"]
    },
    "Branch": {
      "title": "Branch",
      "description": "A shop branch location",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "managerId": { "type": "string" },
        "openingDate": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "inventoryStatus": { "type": "string", "enum": ["synced", "independent"] },
        "dailyCloseStatus": { "type": "string", "enum": ["enabled", "disabled"] },
        "logoUrl": { "type": "string" },
        "shopId": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "timing": { "type": "string" },
            "department": { "type": "string" },
            "currency": { "type": "string" },
            "taxSettings": { "type": "string" },
            "invoicePrefix": { "type": "string" },
            "receiptWidth": { "type": "string", "enum": ["58mm", "80mm"] },
            "receiptFooter": { "type": "string" },
            "printLanguage": { "type": "string", "enum": ["en", "bn", "ar"] },
            "systemLanguage": { "type": "string", "enum": ["en", "bn", "ar"] },
            "whatsappSender": { "type": "string" },
            "autoSendWhatsApp": { "type": "boolean" }
          }
        }
      },
      "required": ["name", "code", "address", "phone", "managerId", "openingDate", "shopId"]
    },
    "WarrantyRecord": {
      "title": "WarrantyRecord",
      "description": "A record of a sold serialized warranty product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "serialNumber": { "type": "string" },
        "warrantyPeriod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "soldPrice": { "type": "number" }
      },
      "required": ["shopId", "productId", "serialNumber", "warrantyPeriod", "createdAt"]
    },
    "MeetSession": {
      "title": "MeetSession",
      "description": "Google Meet session details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "meetLink": { "type": "string" },
        "spaceName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "shopId": { "type": "string" },
        "exportedToSheet": { "type": "boolean" }
      },
      "required": ["title", "startTime", "endTime", "meetLink", "createdAt", "shopId"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A shop product supplier details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "company": { "type": "string" },
        "brand": { "type": "string" },
        "srName": { "type": "string" },
        "srPhone": { "type": "string" },
        "srVisitDay": { "type": "string" },
        "deliveryName": { "type": "string" },
        "deliveryPhone": { "type": "string" },
        "deliveryVisitDay": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "productCount": { "type": "number" }
      },
      "required": ["company", "brand", "srPhone", "shopId"]
    },
    "DraftInvoice": {
      "title": "DraftInvoice",
      "description": "A draft POS invoice configuration",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "cart": { "type": "array" },
        "discount": { "type": "number" },
        "taxRate": { "type": "number" },
        "customerId": { "type": "string" },
        "walkInName": { "type": "string" },
        "walkInPhone": { "type": "string" },
        "finalTotal": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "orderId": { "type": "string" },
        "tableNo": { "type": "string" },
        "waiterId": { "type": "string" },
        "waiterName": { "type": "string" }
      },
      "required": ["shopId", "cart", "finalTotal", "createdAt"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A bug report, feature request, or feedback support ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["bug", "feature", "question", "feedback"] },
        "description": { "type": "string" },
        "screenshot": { "type": "string" },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "in_progress", "resolved", "closed"] },
        "developerNote": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "title", "type", "description", "createdAt"]
    }
  },
  "firestore": {
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Collection of customer support tickets, bug reports, and feedback"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Collection of shop suppliers details"
    },
    "/draft_invoices/{draftId}": {
      "schema": "DraftInvoice",
      "description": "Collection of saved draft invoices configurations"
    },
    "/warranty_records/{recordId}": {
      "schema": "WarrantyRecord",
      "description": "Collection of sold serialized warranty records"
    },
    "/meet_sessions/{recordId}": {
      "schema": "MeetSession",
      "description": "Collection of scheduled Google Meet sessions"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of sales transactions"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of customers"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of system users"
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of shop employees"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of shop expenses"
    },
    "/investments/{investmentId}": {
      "schema": "Investment",
      "description": "Collection of business investments"
    },
    "/staff_salaries/{salaryId}": {
      "schema": "StaffSalary",
      "description": "Collection of staff salary payments"
    },
    "/stockRecords/{recordId}": {
      "schema": "StockRecord",
      "description": "Collection of stock movement records"
    },
    "/recycleBin/{itemId}": {
      "schema": "RecycleItem",
      "description": "Collection of deleted items in bin"
    },
    "/customer_logs/{logId}": {
      "schema": "CustomerLog",
      "description": "Collection of customer edit logs"
    },
    "/due_payments/{paymentId}": {
      "schema": "DuePayment",
      "description": "Collection of customer due payments"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Collection of user notes"
    },
    "/branches/{branchId}": {
      "schema": "Branch",
      "description": "Collection of shop branch locations"
    }
  }
}
